# Discord
DISCORD_TOKEN=your-discord-bot-token
CLIENT_ID=your-discord-application-client-id
GUILD_ID=your-discord-server-id

# Only members with this Discord role can use the SSU / Ban buttons
ADMIN_ROLE_ID=your-staff-role-id

# Roblox Open Cloud (create at https://create.roblox.com/dashboard/credentials)
# Needs ONLY: universe-messaging-service:publish, scoped to the
# "DiscordAdminBridge" topic. The game script does all DataStore writes
# itself, so no datastore scope is needed on this key.
ROBLOX_API_KEY=your-open-cloud-api-key
ROBLOX_UNIVERSE_ID=your-universe-id